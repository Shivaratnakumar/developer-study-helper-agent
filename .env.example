# --- OpenAI / compatible cloud ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# STUDY_HELPER_MODEL=gpt-4o-mini

# --- Ollama (local, no cloud key) ---
# 1) Install Ollama from https://ollama.com and run: ollama pull llama3.2
# 2) Use either:
# STUDY_HELPER_OLLAMA=1
# Optional if Ollama listens elsewhere:
# OLLAMA_HOST=127.0.0.1:11434
# Optional override model (default when Ollama: llama3.2):
# STUDY_HELPER_MODEL=mistral
#
# Or set base URL yourself (no OPENAI_API_KEY needed):
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# STUDY_HELPER_MODEL=llama3.2

# Optional voice (see README): pip install -e ".[voice]" then e.g. study-helper mock-interview "..." --voice
# If STT fails: STUDY_HELPER_MIC_SENSITIVE=1 or STUDY_HELPER_MIC_SKIP_NOISE_ADJUST=1
# Language for Google STT: STUDY_HELPER_SPEECH_LANG=en-US  (try en-IN, en-GB, etc.)

# Optional: where to store progress JSON
# STUDY_HELPER_PROGRESS=%USERPROFILE%\.developer-study-helper\progress.json
